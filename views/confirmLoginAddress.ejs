<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content="7eQAiqaVOF2E1updDXUdkGYOXVtddWSM7aJmtEjl" />

    <title>Stock Invest Trades | Identity Verification</title>

    <link href="/src/output.css" rel="stylesheet" />
    <link
      rel="icon"
      href="storage/app/public/photos/b6kcKsqH4Ns67EZpCTZxhuW1CPTjMNqkOlAdpcA5.png"
      type="image/png"
    />

    <link href="temp/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <!-- Icons -->
    <link href="temp/css/materialdesignicons.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="temp/css/line.css" />
    <script src="../www.google.com/recaptcha/api.js" async defer></script>

    <link href="temp/css/style.css" rel="stylesheet" type="text/css" />
    <link href="temp/css/colors/default.css" rel="stylesheet" />

    <link rel="icon" href="wp-content/uploads/2024/05/Asset-2943eliteiqtrades.png" sizes="32x32" />
    <link
      rel="icon"
      href="wp-content/uploads/2024/05/Asset-2943eliteiqtrades.png"
      sizes="192x192"
    />
    <link rel="apple-touch-icon" href="wp-content/uploads/2024/05/Asset-2943eliteiqtrades.png" />
    <meta
      name="msapplication-TileImage"
      content="https://eliteiqtrades.com/wp-content/uploads/2024/05/Asset-2943eliteiqtrades.png"
    />

    <style>
      .login-page {
        background-color: #14161d !important;
        border: 1px solid #222530 !important;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6) !important;
        position: relative;
      }
      .back-btn {
        position: absolute;
        top: 20px;
        left: 20px;
        color: rgba(255, 255, 255, 0.4);
        transition: all 0.3s ease;
        text-decoration: none !important;
        font-size: 18px;
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .back-btn:hover {
        color: #f0b90b;
        transform: translateX(-3px);
      }
      .form-control {
        background-color: #1e222d !important;
        border: 1px solid #2a2e3d !important;
        color: #ffffff !important;
        border-radius: 6px !important;
        padding: 12px 15px !important;
        height: auto !important;
        letter-spacing: 2px;
      }
      .form-control:focus {
        border-color: #f0b90b !important;
        box-shadow: none !important;
      }
      .form-control::placeholder {
        letter-spacing: normal;
      }
      .btn-primary.btn-block.pad {
        background-color: #f0b90b !important;
        border-color: #f0b90b !important;
        color: #0d0e12 !important;
        font-weight: 600;
        padding: 12px !important;
        border-radius: 6px !important;
        transition: all 0.3s ease;
      }
      .btn-primary.btn-block.pad:hover {
        background-color: #d4af37 !important;
        border-color: #d4af37 !important;
        transform: translateY(-1px);
      }
      .custom-footer {
        color: rgba(255, 255, 255, 0.3);
        font-size: 12px;
        letter-spacing: 0.5px;
      }
      .custom-footer a {
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
      }
      .custom-footer a:hover {
        color: #f0b90b;
      }
    </style>
  </head>
  <body class="h-100 bg-soft-primary" style="background-color: #0d0e12 !important">
    <section class="auth d-flex align-items-center min-vh-100 py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-md-6 col-lg-5">
            <!-- OTP Input Module Container -->
            <div class="card login-page rounded border-1 mb-4">
              <!-- Back Button Link -->
              <a href="/login" class="back-btn" title="Back to Login">
                <i class="mdi mdi-arrow-left"></i>
                <span style="font-size: 13px; font-weight: 500">Login</span>
              </a>

              <div class="card-body p-4 pt-5">
                <h4 class="text-center card-title text-white font-weight-bold mb-2">
                  Security Check
                </h4>
                <p
                  class="text-center mb-4"
                  style="color: rgba(255, 255, 255, 0.5); font-size: 14px"
                >
                  Check your email address for your security OTP code.
                </p>

                <p class="text-center" style="color: white; opacity: 0.5">
                  <%- include ('./partials/messages') %>
                </p>

                <form action="/confirm" method="POST" class="login-form">
                  <div class="row">
                    <div class="col-lg-12 mb-4">
                      <div class="form-group mb-0">
                        <div class="position-relative">
                          <input
                            type="text"
                            class="form-control text-center text-uppercase"
                            name="otp"
                            id="otp"
                            autocomplete="one-time-code"
                            inputmode="numeric"
                            placeholder="Enter Security Code"
                            required
                          />
                        </div>
                      </div>
                    </div>

                    <div class="mb-3 col-lg-12">
                      <button class="btn btn-primary btn-block pad" type="submit">
                        Confirm Identity
                      </button>
                    </div>
                  </div>
                </form>
              </div>
            </div>

            <!-- Dynamic Non-Hardcoded Footer Component -->
            <div class="text-center custom-footer">
              <p class="mb-1">
                &copy; Copyright <%= new Date().getFullYear() %> Stock Invest Trades. All Rights
                Reserved.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <script src="temp/js/jquery-3.5.1.min.js"></script>
    <script src="temp/js/bootstrap.bundle.min.js"></script>
    <script src="temp/js/owl.carousel.min.js"></script>
    <script src="temp/js/owl.init.js"></script>
    <script src="temp/js/feather.min.js"></script>
    <script src="temp/js/app.js"></script>
    <script src="temp/js/widget.js"></script>
  </body>
</html>
