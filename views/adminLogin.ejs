<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stock Invest Trades | Terminal Access</title>

    <link
      rel="icon"
      href="/storage/app/public/photos/b6kcKsqH4Ns67EZpCTZxhuW1CPTjMNqkOlAdpcA5.png"
      type="image/png"
    />

    <link href="/src/output.css" rel="stylesheet" />

    <style>
      /* Smooth pulsing radial glow for that deep cryptographic vault theme */
      body {
        background-color: #0b0c10;
        background-image: radial-gradient(circle at center, #11141d 0%, #07080a 100%);
      }
      /* Hide standard numeric arrows in browsers */
      input::-webkit-outer-spin-button,
      input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
      }
      input[type="number"] {
        -moz-appearance: textfield;
      }
    </style>
  </head>
  <body
    class="h-screen w-screen flex flex-col justify-between items-center text-white antialiased selection:bg-yellow-500 selection:text-black"
  >
    <div></div>

    <div class="w-full max-w-md px-6">
      <div
        class="bg-[#14161d] border border-[#222530] rounded-2xl p-8 shadow-2xl transition-all duration-300 hover:border-yellow-600/30"
      >
        <div class="text-center mb-8">
          <div
            class="inline-block text-xs font-bold tracking-[0.25em] text-yellow-500 uppercase mb-2"
          >
            System Overseer
          </div>
          <h2 class="text-2xl font-bold tracking-tight text-white">Terminal Access</h2>
        </div>

        <div class="text-center text-sm font-medium text-red-400 mb-2">
          <%- include ('./partials/messages') %>
        </div>

        <form action="/admin-login" method="POST" class="space-y-6">
          <div>
            <div class="relative">
              <input
                type="password"
                inputmode="numeric"
                pattern="[0-9]*"
                maxlength="4"
                name="pin"
                id="pin"
                placeholder="••••"
                maxlength="4"
                required
                autofocus
                class="w-full text-center text-3xl font-bold tracking-[0.5em] pl-4 py-4 bg-[#1e222d] border border-[#2a2e3d] text-white rounded-xl placeholder:text-[#4b526d] placeholder:tracking-normal outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition-all duration-200"
              />
            </div>
            <p class="text-center text-xs text-[#636a7e] mt-3">
              Enter secure 4-digit administrative PIN code
            </p>
          </div>

          <button
            type="submit"
            class="w-full py-4 bg-yellow-500 hover:bg-yellow-600 text-[#0d0e12] text-sm font-bold uppercase tracking-wider rounded-xl transition-all duration-300 transform active:scale-[0.99] shadow-lg shadow-yellow-500/10 hover:shadow-yellow-500/20"
          >
            Authenticate Credentials
          </button>
        </form>
      </div>
    </div>

    <div class="w-full text-center pb-8 text-xs text-[#4b526d] tracking-wide space-y-1">
      <p>
        &copy; Copyright <%= new Date().getFullYear() %> Stock Invest Trades &bull; Root Console
      </p>
    </div>
  </body>
</html>
